  WARD
}

enum RomanceGenre {
  BL
  GL
  HETEROSEXUAL
  OTHER
}

model Genre {
  id     String       @id @default(uuid()) @db.Uuid
  slug   String       @unique @db.VarChar(80)
  label  String       @db.VarChar(120)
  novels NovelGenre[]

  @@map("genres")
}

model CatalogLanguage {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(120)
  code        String   @unique @db.VarChar(20)
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  novels      Novel[]

  @@map("cat_language")
}

model Novel {
  id         String      @id @default(uuid()) @db.Uuid
  authorId   String      @map("author_id") @db.Uuid
  languageId String      @map("language_id") @db.Uuid
  title      String      @db.VarChar(200)
  slug       String      @unique @db.VarChar(220)
  synopsis   String?     @db.Text
  coverUrl   String?     @map("cover_url")
  status     NovelStatus @default(DRAFT)
  rating     NovelRating @default(G)
  tags       String[]
  warnings   String[]
  isPublic   Boolean     @default(false) @map("is_public")
  wordCount  Int         @default(0) @map("word_count")
  viewsCount Int         @default(0) @map("views_count")
  kudosCount Int         @default(0) @map("kudos_count")
  votesCount Int         @default(0) @map("votes_count")
  totalWordsCount   Int    @default(0) @map("total_words_count")
  chaptersCount     Int    @default(0) @map("chapters_count")
  subscribersCount  Int    @default(0) @map("subscribers_count")
  romanceGenres     RomanceGenre[] @default([]) @map("romance_genres")
  novelType         NovelType   @default(ORIGINAL) @map("novel_type")
  isAlternateUniverse Boolean   @default(false) @map("is_alternate_universe")
  linkedCommunityId String?     @map("linked_community_id") @db.Uuid
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  author           User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  language         CatalogLanguage   @relation(fields: [languageId], references: [id])
  chapters         Chapter[]
  genres           NovelGenre[]
  likes            NovelLike[]
  bookmarks        NovelBookmark[]
  readingProgress  ReadingProgress[]
  readingHistory   ReadingHistory[]
  chapterBookmarks ChapterBookmark[]
  highlights       Highlight[]
  readingListItems ReadingListItem[]
  novelWorlds      NovelWorld[]
  novelCharacters  NovelCharacter[]
  timelines            Timeline[]
  writingProjects      WritingProject[]
  novelDailySnapshots  NovelDailySnapshot[]
  kudos                NovelKudo[]
  seriesNovels         SeriesNovel[]
  subscriptions        NovelSubscription[]
  pairings             NovelPairing[]
  linkedCommunities    Community[]        @relation("CommunityLinkedNovel")
  linkedCommunity      Community?         @relation("FanficCommunity", fields: [linkedCommunityId], references: [id], onDelete: SetNull)
  relatedInCommunities CommunityRelatedNovel[] @relation("RelatedInCommunities")

  @@index([authorId])
  @@index([slug])
  @@index([status, isPublic])
  @@index([createdAt])
  @@index([languageId])
  @@index([linkedCommunityId])
  @@map("novels")
}

model Series {
  id          String       @id @default(uuid()) @db.Uuid
  authorId    String       @map("author_id") @db.Uuid
  parentId    String?      @map("parent_id") @db.Uuid
  title       String       @db.VarChar(300)
  slug        String       @unique @db.VarChar(320)
  description String?      @db.Text
  type        SeriesType   @default(SAGA)
  status      SeriesStatus @default(IN_PROGRESS)
  coverUrl    String?      @map("cover_url")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  author   User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Series?       @relation("SeriesNesting", fields: [parentId], references: [id], onDelete: SetNull)
  children Series[]      @relation("SeriesNesting")
  novels   SeriesNovel[]

  @@index([authorId])
  @@index([slug])
  @@index([type, status])
  @@index([parentId])
  @@map("series")
}

model VisualBoard {
  id          String   @id @default(uuid()) @db.Uuid
  authorId    String   @map("author_id") @db.Uuid
  title       String   @db.VarChar(200)
  description String?  @db.VarChar(500)
  coverUrl    String?  @map("cover_url")
  isPublic    Boolean  @default(false) @map("is_public")
  linkedType  String?  @map("linked_type") @db.VarChar(50)
  linkedId    String?  @map("linked_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  author   User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  sections VisualBoardSection[]

  @@index([authorId])
  @@index([linkedType, linkedId])
  @@map("visual_boards")
}

model VisualBoardSection {
  id         String   @id @default(uuid()) @db.Uuid
  boardId    String   @map("board_id") @db.Uuid
  title      String   @db.VarChar(200)
  orderIndex Int      @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  board VisualBoard       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  items VisualBoardItem[]

  @@index([boardId])
  @@unique([boardId, orderIndex])
  @@map("visual_board_sections")
}

model VisualBoardItem {
  id         String   @id @default(uuid()) @db.Uuid
  sectionId  String   @map("section_id") @db.Uuid
  imageUrl   String   @map("image_url")
  caption    String?  @db.VarChar(300)
  orderIndex Int      @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")

  section VisualBoardSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@unique([sectionId, orderIndex])
  @@map("visual_board_items")
}

model SeriesNovel {
  seriesId   String @map("series_id") @db.Uuid
  novelId    String @map("novel_id") @db.Uuid
  orderIndex Int    @map("order_index")

  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  novel  Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@id([seriesId, novelId])
  @@unique([seriesId, orderIndex])
  @@index([novelId])
  @@map("series_novels")
}

model NovelSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  novelId   String   @map("novel_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([novelId, userId])
  @@index([novelId])
  @@index([userId])
  @@map("novel_subscriptions")
}

model NovelGenre {
  novelId String @map("novel_id") @db.Uuid
  genreId String @map("genre_id") @db.Uuid

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([novelId, genreId])
  @@map("novel_genres")
}

model Chapter {
  id              String        @id @default(uuid()) @db.Uuid
  novelId         String        @map("novel_id") @db.Uuid
  authorId        String        @map("author_id") @db.Uuid
  title           String        @db.VarChar(300)
  slug            String        @db.VarChar(320)
  content         String        @db.Text
  order           Int
  status          ChapterStatus @default(DRAFT)
  wordCount       Int           @default(0) @map("word_count")
  scheduledAt     DateTime?     @map("scheduled_at")
  publishedAt     DateTime?     @map("published_at")
  contentSnapshot Json?         @map("content_snapshot")
  votesCount      Int           @default(0) @map("votes_count")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  novel            Novel             @relation(fields: [novelId], references: [id], onDelete: Cascade)
  author           User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  readingProgress  ReadingProgress[]
  readingHistory   ReadingHistory[]
  chapterBookmarks ChapterBookmark[]
  highlights       Highlight[]
  timelineEvents   TimelineEvent[]
  writingTasks     WritingTask[]
  chapterVotes     ChapterVote[]

  @@unique([novelId, slug])
  @@unique([novelId, order])
  @@index([novelId, status])
  @@index([novelId, order])
  @@index([slug])             // chapter slug lookups
  @@map("chapters")
}

model NovelLike {
  id        String   @id @default(uuid()) @db.Uuid
  novelId   String   @map("novel_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([novelId, userId])
  @@index([novelId])
  @@index([userId])
  @@map("novel_likes")
}

model NovelBookmark {
  id        String   @id @default(uuid()) @db.Uuid
  novelId   String   @map("novel_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([novelId, userId])
  @@index([userId])
  @@map("novel_bookmarks")
}

model NovelKudo {
  id        String   @id @default(uuid()) @db.Uuid
  novelId   String   @map("novel_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([novelId, userId])
  @@index([novelId])
  @@index([userId])
  @@map("novel_kudos")
}

model CharacterKudo {
  id          String   @id @default(uuid()) @db.Uuid
  characterId String   @map("character_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([characterId, userId])
  @@index([characterId])
  @@index([userId])
  @@map("character_kudos")
}

model WorldKudo {
  id        String   @id @default(uuid()) @db.Uuid
  worldId   String   @map("world_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([worldId, userId])
  @@index([worldId])
  @@index([userId])
  @@map("world_kudos")
}

model ChapterVote {
  id        String   @id @default(uuid()) @db.Uuid
  chapterId String   @map("chapter_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chapterId, userId])
  @@index([chapterId])
  @@index([userId])
  @@map("chapter_votes")
}

model ReaderPreferences {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @unique @map("user_id") @db.Uuid
  fontFamily   ReaderFontFamily @default(crimson) @map("font_family")
  fontSize     Int              @default(18) @map("font_size")
  lineHeight   Float            @default(1.8) @map("line_height")
  maxWidth     Int              @default(720) @map("max_width")
  readingMode  ReaderMode       @default(scroll) @map("reading_mode")
  showProgress Boolean          @default(true) @map("show_progress")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reader_preferences")
}

model ReadingProgress {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  novelId   String   @map("novel_id") @db.Uuid
  chapterId String   @map("chapter_id") @db.Uuid
  scrollPct Float    @default(0) @map("scroll_pct")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel   Novel   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@index([userId])
  @@index([novelId])
  @@map("reading_progress")
}

model ReadingHistory {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  novelId   String   @map("novel_id") @db.Uuid
  chapterId String   @map("chapter_id") @db.Uuid
  openedAt  DateTime @default(now()) @map("opened_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel   Novel   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([userId, openedAt])
  @@map("reading_history")
}

model ChapterBookmark {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  chapterId String   @map("chapter_id") @db.Uuid
  novelId   String   @map("novel_id") @db.Uuid
  anchorId  String?  @map("anchor_id")
  label     String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  novel   Novel   @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chapterId])
  @@map("chapter_bookmarks")
}

model Highlight {
