  ANTAGONIST
  SECONDARY
  MENTOR
  ALLY
  RIVAL
  NEUTRAL
  BACKGROUND
}

enum CharacterStatus {
  ALIVE
  DECEASED
  UNKNOWN
  UNDEAD
  TRANSFORMED
}

enum CharacterRelationshipCategory {
  KINSHIP
  OTHER
}

enum CharacterKinshipType {
  PARENT
  CHILD
  SIBLING
  GRANDPARENT
  GRANDCHILD
  UNCLE_AUNT
  NIECE_NEPHEW
