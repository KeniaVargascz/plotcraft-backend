// ── Forum Enums & Models ──

enum ForumCategory {
  GENERAL
  FEEDBACK
  WRITING_TIPS
  WORLD_BUILDING
  CHARACTERS
  SHOWCASE
  ANNOUNCEMENTS
  HELP
  OFF_TOPIC
}

enum ThreadStatus {
  OPEN
  CLOSED
  PINNED
  ARCHIVED
}

enum PollStatus {
  OPEN
  CLOSED
}

enum ForumReactionType {
  LIKE
  HELPFUL
  INSIGHTFUL
  FUNNY
}

model ForumThread {
  id             String        @id @default(uuid()) @db.Uuid
  authorId       String        @map("author_id") @db.Uuid
  forumId        String?       @map("forum_id") @db.Uuid
  category       ForumCategory @default(GENERAL)
  title          String        @db.VarChar(300)
  slug           String        @unique @db.VarChar(320)
  content        String        @db.Text
  status         ThreadStatus  @default(OPEN)
  isPinned       Boolean       @default(false) @map("is_pinned")
  viewsCount     Int           @default(0) @map("views_count")
  repliesCount   Int           @default(0) @map("replies_count")
  reactionsCount Int           @default(0) @map("reactions_count")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  author             User                     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  forum              CommunityForum?          @relation(fields: [forumId], references: [id], onDelete: SetNull)
  replies            ForumReply[]
  reactions          ForumReaction[]
  poll               ForumPoll?
  tags               ForumThreadTag[]
  linkedCommunities  ThreadCommunityLink[]

  @@index([category, status, createdAt])
  @@index([authorId])
  @@index([slug])
  @@index([forumId])
  @@map("forum_threads")
}

model ThreadCommunityLink {
  threadId    String   @map("thread_id") @db.Uuid
  communityId String   @map("community_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  community Community   @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@id([threadId, communityId])
  @@index([communityId])
  @@map("thread_community_links")
}

model CommunityForum {
  id           String   @id @default(uuid()) @db.Uuid
  communityId  String   @map("community_id") @db.Uuid
  name         String   @db.VarChar(200)
  slug         String   @db.VarChar(220)
  description  String?  @db.VarChar(500)
  rules        String?  @db.Text
  isPublic     Boolean  @default(true) @map("is_public")
  membersCount Int      @default(0) @map("members_count")
  threadsCount Int      @default(0) @map("threads_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  community    Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  threads      ForumThread[]
  forumMembers ForumMember[]

  @@unique([communityId, slug])
  @@index([communityId])
  @@map("community_forums")
}

model ForumMember {
  id       String   @id @default(uuid()) @db.Uuid
  forumId  String   @map("forum_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")

  forum CommunityForum @relation(fields: [forumId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([forumId, userId])
  @@index([forumId])
  @@index([userId])
  @@map("forum_members")
}

model ForumThreadTag {
  threadId String @map("thread_id") @db.Uuid
  tag      String @db.VarChar(50)

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@id([threadId, tag])
  @@index([tag])
  @@map("forum_thread_tags")
}

model ForumReply {
  id            String    @id @default(uuid()) @db.Uuid
  threadId      String    @map("thread_id") @db.Uuid
  authorId      String    @map("author_id") @db.Uuid
  parentReplyId String?   @map("parent_reply_id") @db.Uuid
  content       String    @db.Text
  isSolution    Boolean   @default(false) @map("is_solution")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  thread       ForumThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author       User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions    ForumReaction[]
  parentReply  ForumReply?      @relation("ReplyChildren", fields: [parentReplyId], references: [id], onDelete: Cascade)
  childReplies ForumReply[]     @relation("ReplyChildren")

  @@index([threadId, createdAt])
  @@index([authorId])
  @@index([parentReplyId])
  @@map("forum_replies")
}

model ForumReaction {
  id           String            @id @default(uuid()) @db.Uuid
  userId       String            @map("user_id") @db.Uuid
  threadId     String?           @map("thread_id") @db.Uuid
  replyId      String?           @map("reply_id") @db.Uuid
  reactionType ForumReactionType @default(LIKE) @map("reaction_type")
  createdAt    DateTime          @default(now()) @map("created_at")

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread ForumThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  reply  ForumReply?  @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId, reactionType])
  @@unique([userId, replyId, reactionType])
  @@index([threadId])
  @@index([replyId])
  @@map("forum_reactions")
}

model ForumPoll {
  id        String     @id @default(uuid()) @db.Uuid
  threadId  String     @unique @map("thread_id") @db.Uuid
  question  String     @db.VarChar(300)
  status    PollStatus @default(OPEN)
  closesAt  DateTime?  @map("closes_at")
  createdAt DateTime   @default(now()) @map("created_at")

  thread  ForumThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  @@map("forum_polls")
}

model PollOption {
  id     String @id @default(uuid()) @db.Uuid
  pollId String @map("poll_id") @db.Uuid
  text   String @db.VarChar(200)
  order  Int    @default(0)

  poll  ForumPoll  @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id        String   @id @default(uuid()) @db.Uuid
  pollId    String   @map("poll_id") @db.Uuid
  optionId  String   @map("option_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  poll   ForumPoll  @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId])
  @@index([userId])
  @@map("poll_votes")
}

// ── Settings & Notifications Models ──

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationType {
  NEW_FOLLOWER
  NEW_COMMENT
  NEW_REACTION
  NEW_REPLY
  NEW_CHAPTER
  NOVEL_MILESTONE
  SYSTEM
  CHAPTER_PUBLISHED
  COMMUNITY_APPROVED
  COMMUNITY_REJECTED
  COMMUNITY_REVIEW
  SUGGESTION_APPROVED
  SUGGESTION_REJECTED
}

model PrivacySettings {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @unique @map("user_id") @db.Uuid
  showReadingActivity Boolean  @default(true) @map("show_reading_activity")
  showReadingLists    Boolean  @default(true) @map("show_reading_lists")
  showFollows         Boolean  @default(true) @map("show_follows")
  showStats           Boolean  @default(true) @map("show_stats")
  allowMessages       Boolean  @default(true) @map("allow_messages")
  searchable          Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("privacy_settings")
}

model NotificationPreferences {
  id                      String              @id @default(uuid()) @db.Uuid
  userId                  String              @unique @map("user_id") @db.Uuid
  newFollower             Boolean             @default(true) @map("new_follower")
  newCommentOnPost        Boolean             @default(true) @map("new_comment_on_post")
  newReactionOnPost       Boolean             @default(false) @map("new_reaction_on_post")
  newReplyInThread        Boolean             @default(true) @map("new_reply_in_thread")
  newChapterFromFollowed  Boolean             @default(true) @map("new_chapter_from_followed")
  novelMilestone          Boolean             @default(true) @map("novel_milestone")
  channel                 NotificationChannel @default(IN_APP)
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(200)
  body      String           @db.VarChar(500)
  url       String?          @db.VarChar(500)
  isRead    Boolean          @default(false) @map("is_read")
  actorId   String?          @map("actor_id") @db.Uuid
  createdAt DateTime         @default(now()) @map("created_at")

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ── Analytics Snapshots ──

model NovelDailySnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  novelId      String   @map("novel_id") @db.Uuid
  date         DateTime @db.Date
  views        Int      @default(0)
  likes        Int      @default(0)
  bookmarks    Int      @default(0)
  newReaders   Int      @default(0) @map("new_readers")
  chaptersRead Int      @default(0) @map("chapters_read")
  wordsRead    Int      @default(0) @map("words_read")

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([novelId, date])
  @@index([novelId, date])
  @@map("novel_daily_snapshots")
}

model AuthorDailySnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  authorId       String   @map("author_id") @db.Uuid
  date           DateTime @db.Date
  newFollowers   Int      @default(0) @map("new_followers")
  profileViews   Int      @default(0) @map("profile_views")
  postReactions  Int      @default(0) @map("post_reactions")

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([authorId, date])
  @@index([authorId, date])
  @@map("author_daily_snapshots")
}

// ── Map Editor ──

enum MarkerType {
  CITY
  TOWN
  VILLAGE
  DUNGEON
  LANDMARK
  RUINS
  TEMPLE
  FORTRESS
  PORT
  MOUNTAIN
  FOREST
  CUSTOM
}

model WorldMap {
  id            String   @id @default(uuid()) @db.Uuid
  worldId       String   @unique @map("world_id") @db.Uuid
  baseImageUrl  String?  @map("base_image_url")
  viewport      Json     @default("{\"x\":0,\"y\":0,\"zoom\":1}")
  canvasWidth   Int      @default(2000) @map("canvas_width")
  canvasHeight  Int      @default(1500) @map("canvas_height")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  world   World       @relation(fields: [worldId], references: [id], onDelete: Cascade)
  markers MapMarker[]
  regions MapRegion[]

  @@map("world_maps")
}

model MapMarker {
  id          String     @id @default(uuid()) @db.Uuid
  mapId       String     @map("map_id") @db.Uuid
  label       String     @db.VarChar(100)
  type        MarkerType @default(CUSTOM)
  x           Float
  y           Float
  description String?    @db.VarChar(500)
  icon        String?    @db.VarChar(10)
  color       String?    @db.VarChar(20)
  locationId  String?    @map("location_id") @db.Uuid
  wbEntryId   String?    @map("wb_entry_id") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  map      WorldMap        @relation(fields: [mapId], references: [id], onDelete: Cascade)
  location WorldLocation?  @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([mapId])
  @@map("map_markers")
}

model MapRegion {
  id          String   @id @default(uuid()) @db.Uuid
  mapId       String   @map("map_id") @db.Uuid
  label       String   @db.VarChar(100)
  color       String   @default("#8b5cf640")
  borderColor String   @default("#8b5cf6") @map("border_color")
  points      Json
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  map WorldMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([mapId])
  @@map("map_regions")
}

// ── Communities ──

enum CommunityType {
  PRIVATE
  PUBLIC
  FANDOM
}

enum CommunityStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum CommunityMemberRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum CommunityMemberStatus {
  ACTIVE
  BANNED
}

model Community {
  id              String          @id @default(uuid()) @db.Uuid
  ownerId         String          @map("owner_id") @db.Uuid
  type            CommunityType
  status          CommunityStatus @default(PENDING)
  name            String          @db.VarChar(200)
  slug            String          @unique @db.VarChar(220)
  description     String?         @db.Text
  coverUrl        String?         @map("cover_url")
  bannerUrl       String?         @map("banner_url")
  linkedNovelId   String?         @map("linked_novel_id") @db.Uuid
  rules           String?         @db.Text
  rejectionReason String?         @map("rejection_reason") @db.VarChar(500)
  membersCount    Int             @default(0) @map("members_count")
  followersCount  Int             @default(0) @map("followers_count")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  owner       User              @relation("OwnedCommunities", fields: [ownerId], references: [id], onDelete: Cascade)
  linkedNovel Novel?            @relation("CommunityLinkedNovel", fields: [linkedNovelId], references: [id], onDelete: SetNull)
  members        CommunityMember[]
  follows        CommunityFollow[]
  forums         CommunityForum[]
  linkedThreads  ThreadCommunityLink[]
  fanficNovels   Novel[]              @relation("FanficCommunity")
  communityCharacters CommunityCharacter[] @relation("CommunityCharacters")
  relatedNovels  CommunityRelatedNovel[] @relation("CommunityRelatedNovels")

  @@index([ownerId])
  @@index([type, status])
  @@index([slug])
  @@map("communities")
}

model CommunityMember {
  id          String                @id @default(uuid()) @db.Uuid
  communityId String                @map("community_id") @db.Uuid
  userId      String                @map("user_id") @db.Uuid
  role        CommunityMemberRole   @default(MEMBER)
  status      CommunityMemberStatus @default(ACTIVE)
  joinedAt    DateTime              @default(now()) @map("joined_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@map("community_members")
}

model CommunityFollow {
  id          String   @id @default(uuid()) @db.Uuid
  communityId String   @map("community_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@map("community_follows")
}

model CommunityRelatedNovel {
  communityId String   @map("community_id") @db.Uuid
  novelId     String   @map("novel_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  community Community @relation("CommunityRelatedNovels", fields: [communityId], references: [id], onDelete: Cascade)
  novel     Novel     @relation("RelatedInCommunities", fields: [novelId], references: [id], onDelete: Cascade)

  @@id([communityId, novelId])
  @@index([novelId])
  @@map("community_related_novels")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
